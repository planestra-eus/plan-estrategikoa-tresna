  const open = q.openId ? `<div style="margin-top:8px"><label>${esc(q.openLabel)}</label><textarea oninput="state.eval['${q.openId}']=this.value">${esc(state.eval[q.openId]||'')}</textarea></div>` : '';
  return `<div><label>${esc(q.label)}</label>${control}${open}</div>`;

  const axisRows=axes.map(ax=>{const r=axisStats(ax); const pct=r.avg?Math.max(0,Math.min(100,Number(r.avg)/4*100)):0; return `<div class="axis-row" title="${esc(r.axis)}"><div class="axis-label">${esc(shortAxisName(r.axis))}</div><div class="axis-track"><div class="axis-fill" style="width:${pct}%"></div></div><div><b>${r.avg||'-'}</b></div></div>`}).join('');
  if($('axisAvgChart')) $('axisAvgChart').innerHTML=axisRows;
  const dist=levelDistribution(); const max=Math.max(1,...Object.values(dist)); const distRows=['0','1','2','3','4'].map(k=>`<div class="dist-row"><div>${k} - ${esc(LEVELS[k])}</div><div class="dist-track"><div class="dist-fill" style="width:${dist[k]/max*100}%"></div></div><div><b>${dist[k]}</b></div></div>`).join('');
  if($('levelDistChart')) $('levelDistChart').innerHTML=distRows;

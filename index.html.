function renderSummary(){
  const total=CRITERIA.length; const answers=Object.values(state.answers); const done=answers.filter(a=>a.maila).length; const zeros=answers.filter(a=>a.maila==='0').length; const mains=answers.filter(a=>a.main).length; const valued=answers.filter(a=>['1','2','3','4'].includes(a.maila)); const avg=valued.length?(valued.reduce((s,a)=>s+Number(a.maila),0)/valued.length).toFixed(2):'-';

  <section class="panel app-section active" id="sec-argibideak">
    <h2>Tresnaren erabilera</h2>
    <p class="hint">Atal honetan tresna erabiltzeko jarraibide nagusiak jasotzen dira. Hasi aurretik, komeni da argibideak irakurtzea.</p>
    <div class="info-tabs">
      <input type="radio" name="infoTabs" id="info1" checked>
      <input type="radio" name="infoTabs" id="info2">
      <input type="radio" name="infoTabs" id="info3">
      <input type="radio" name="infoTabs" id="info4">
      <input type="radio" name="infoTabs" id="info5">
      <input type="radio" name="infoTabs" id="info6">
      <div class="info-tab-labels">
        <label for="info1">Helburua</label>
        <label for="info2">Lan egiteko modua</label>
        <label for="info3">Segurtasuna</label>
        <label for="info4">Zirriborroa gorde/kargatu</label>

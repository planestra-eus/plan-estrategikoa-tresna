function criterionHtml(c){const a=state.answers[String(c.zk)]; const levels=['0','1','2','3','4'].map(k=>`<div class="level ${k==='0'?'zero':''}"><b>${k} - ${LEVELS[k]}</b><span class="small">${k==='0'?'Irizpidea ezin da modu egokian baloratu. Arrazoitu egin behar da.':esc(c.mailak?.[k]||'')}</span></div>`).join(''); return `<article class="criterion"><div class="crit-head"><div class="zk">${c.zk}</div><div><div class="crit-title">${esc(c.adierazlea)}</div><div class="hint">${esc(c.ardatza)}</div></div><span class="badge">Irizpidea</span></div><div class="crit-body"><div class="explain"><b>Irizpidearen azalpena</b><br>${esc(c.azalpena||'')}</div><details><summary>Ebidentzia eta iturri orientagarriak</summary><div class="evidence">${esc(c.ebidentziak||'')}</div></details><details><summary>Mailen deskribapena</summary><div class="levels">${levels}</div></details><div class="answer-grid"><div><label>Balorazioa</label><select onchange="setAnswer(${c.zk},'maila',this.value);renderCriteria();renderAll();"><option value="">Aukeratu...</option>${['0','1','2','3','4'].map(k=>`<option value="${k}" ${a.maila===k?'selected':''}>${k} - ${LEVELS[k]}</option>`).join('')}</select></div><div><label>Hobekuntza-lehentasuna</label><select onchange="setAnswer(${c.zk},'lehentasuna',this.value);renderAll();"><option value="Ez" ${a.lehentasuna==='Ez'?'selected':''}>Ez</option><option value="Txikia" ${a.lehentasuna==='Txikia'?'selected':''}>Bai, txikia</option><option value="Ertaina" ${a.lehentasuna==='Ertaina'?'selected':''}>Bai, ertaina</option><option value="Handia" ${a.lehentasuna==='Handia'?'selected':''}>Bai, handia</option></select></div><div class="conditional ${a.maila==='0'?'show':''}"><label>0 aukeraren azalpena</label><textarea oninput="setAnswer(${c.zk},'ezDagoAzalpena',this.value)" placeholder="Zergatik ez dagokio edo zergatik ezin da baloratu?">${esc(a.ezDagoAzalpena)}</textarea></div><div><label>Ohar laburra</label><textarea oninput="setAnswer(${c.zk},'oharra',this.value)" placeholder="Aukerakoa">${esc(a.oharra)}</textarea></div></div></div></article>`}
function setAnswer(zk,key,val){state.answers[String(zk)][key]=val; if(key==='lehentasuna' && (val==='Ez'||val==='Txikia')) state.answers[String(zk)].main=false;}
function axisStats(ax){const cs=CRITERIA.filter(c=>c.ardatza===ax); const arr=cs.map(c=>state.answers[String(c.zk)]); const valued=arr.filter(a=>['1','2','3','4'].includes(a.maila)); const avg=valued.length? valued.reduce((s,a)=>s+Number(a.maila),0)/valued.length:null; return {axis:ax,total:cs.length,done:arr.filter(a=>a.maila).length,valued:valued.length,zero:arr.filter(a=>a.maila==='0').length,avg:avg?avg.toFixed(2):'',medhigh:arr.filter(a=>['Ertaina','Handia'].includes(a.lehentasuna)).length,main:arr.filter(a=>a.main).length};}
function shortAxisName(ax){return String(ax||'').replace(/^\d+\.\s*/,'');}
function levelDistribution(){const d={'0':0,'1':0,'2':0,'3':0,'4':0}; Object.values(state.answers).forEach(a=>{if(d[a.maila]!==undefined) d[a.maila]++;}); return d;}
function orientationFocus(c){
  const t = ((c.adierazlea||'')+' '+(c.azalpena||'')+' '+(c.ardatza||'')).toLowerCase();
  if(t.includes('hizkuntza') || t.includes('euskara') || t.includes('euskal kultura') || t.includes('eleaniz')) return 'hizkuntza-proiektuaren garapena, euskararen erabilera esanguratsua eta ikasleen komunikazio-konpetentzia';
  if(t.includes('bizikidetza') || t.includes('hezkidetza') || t.includes('ongizate') || t.includes('jazarpen') || t.includes('bat talde')) return 'bizikidetza positiboa, hezkidetza, prebentzioa eta ongizate sozioemozionala';
  if(t.includes('digital') || t.includes('teknologia') || t.includes('adimen artifizial') || t.includes('arrakala')) return 'konpetentzia digitala, teknologia digitalen erabilera segurua eta ikaskuntzarako baliabide digitalen integrazioa';
  if(t.includes('jasangar') || t.includes('ekosozial') || t.includes('energia')) return 'jasangarritasuna, kontsumo arduratsua eta proiektu ekosozialen garapena';
  if(t.includes('nazioarte') || t.includes('erasmus') || t.includes('etwinning') || t.includes('atzerriko')) return 'nazioartekotzea, ikuspegi eleanitza eta kulturarteko esperientzien eragina';
  if(t.includes('ebaluazio') || t.includes('autoebaluazio') || t.includes('datu') || t.includes('ikerketa') || t.includes('berrikuntza') || t.includes('esperimentazio')) return 'ebaluazioaren kultura, datuen erabilera pedagogikoa eta berrikuntza ebidentzietan oinarritzea';
  if(t.includes('aniztasun') || t.includes('inklus') || t.includes('irisgarritasun') || t.includes('idu') || t.includes('oztopo')) return 'ikasleen presentzia, parte-hartzea, ikaskuntza eta aurrerapena bermatzen dituen erantzun inklusiboa';
  if(t.includes('famil') || t.includes('komunitate') || t.includes('lankidetza') || t.includes('sare')) return 'hezkuntza-komunitatearen parte-hartzea, erantzukidetasuna eta lankidetza-sareak';
  if(t.includes('irakasle') || t.includes('prestakuntza') || t.includes('praktika-komunitate') || t.includes('talentu')) return 'irakasleen garapen profesionala, lankidetza eta lidergo partekatua';
  if(t.includes('metodologia') || t.includes('ikas-irakaskuntza') || t.includes('ikaskuntza') || t.includes('espazio')) return 'ikas-irakaskuntza prozesuen diseinua, metodologia aktiboak eta ikasleen protagonismoa';
  if(t.includes('zuzendaritza') || t.includes('lidergo') || t.includes('hezkuntza proiektu')) return 'lidergo pedagogikoa, plangintza estrategikoa eta ikastetxearen norabide partekatua';
  return 'irizpide honetan aztertzen den jardun-eremua';
}

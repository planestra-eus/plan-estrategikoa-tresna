  else if(q.type==='ease'){control=`<select onchange="state.eval['${q.id}']=this.value"><option value="">Aukeratu...</option><option ${v==='1'?'selected':''} value="1">1 - Oso zaila</option><option ${v==='2'?'selected':''} value="2">2 - Zaila</option><option ${v==='3'?'selected':''} value="3">3 - Erraza</option><option ${v==='4'?'selected':''} value="4">4 - Oso erraza</option></select>`;}
